{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/informe-mensual",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/recordatorio-convocatoria",
      "schedule": "0 20 * * 5"
    },
    {
      "path": "/api/cron/recordatorio-estadisticas",
      "schedule": "0 20 * * 0"
    }
  ]
}
